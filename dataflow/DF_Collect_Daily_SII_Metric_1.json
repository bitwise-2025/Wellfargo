{
	"name": "DF_Collect_Daily_SII_Metric_1",
	"properties": {
		"description": "Reads daily SII vulnerability alert metrics from vw_SII_EmailAlerts_Details, adds an Import_Date derived column (tomorrow's date), and inserts all rows into tbl_SII_Vuln_History_Alerts.",
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "Generic_src_parquet",
						"type": "DatasetReference"
					},
					"name": "DailySIIMetricView",
					"description": "OLE DB Source: reads [dbo].[vw_SII_EmailAlerts_Details] from PLHS (AccessMode=0, full view scan)"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "Generic_tgt_parquet",
						"type": "DatasetReference"
					},
					"name": "SinkVulnHistoryAlerts",
					"description": "OLE DB Destination: inserts into [dbo].[tbl_SII_Vuln_History_Alerts] (fast-load, insert-only; ID column is identity and excluded from mapping)"
				}
			],
			"transformations": [
				{
					"name": "ImportDate",
					"description": "Derived Column: adds Import_Date = toDate(addDays(currentDate(), 1)). Translated from SSIS expression: (DT_DBDATE)DATEADD(\"day\",1,GETDATE())"
				},
				{
					"name": "SelectForSink",
					"description": "Select: explicitly maps all 20 output columns to the sink in the correct order, excluding the identity column ID which is auto-generated by SQL Server"
				}
			],
			"scriptLines": [
				"source(output(",
				"          TotlInst as integer,",
				"          EmergencyCount as integer,",
				"          HMLCount_App as integer,",
				"          HMLCount_ProdPlat as integer,",
				"          Non_HMLCount_App as integer,",
				"          Non_HMLCount_ProdPlat as integer,",
				"          TechnicalManager_App1 as string,",
				"          Senior_Lead_Supplimented as string,",
				"          CIO_Direct_Supplimented as string,",
				"          Email_Level as string,",
				"          subject_ as string,",
				"          EMHAstatement as string,",
				"          HMLAPP as string,",
				"          HML_ProdPlat as string,",
				"          Non_HML_App as string,",
				"          Non_HML_ProdPlat as string,",
				"          SrMngrEmail as string,",
				"          CIOdirEmail as string,",
				"          TechMngrEmail as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false,",
				"     format: 'parquet') ~> DailySIIMetricView",
				"DailySIIMetricView derive(Import_Date = addDays(currentDate(), 1)) ~> ImportDate",
				"ImportDate select(mapColumn(",
				"          TotlInst,",
				"          EmergencyCount,",
				"          HMLCount_App,",
				"          HMLCount_ProdPlat,",
				"          Non_HMLCount_App,",
				"          Non_HMLCount_ProdPlat,",
				"          TechnicalManager_App1,",
				"          Senior_Lead_Supplimented,",
				"          CIO_Direct_Supplimented,",
				"          Email_Level,",
				"          subject_,",
				"          EMHAstatement,",
				"          HMLAPP,",
				"          HML_ProdPlat,",
				"          Non_HML_App,",
				"          Non_HML_ProdPlat,",
				"          SrMngrEmail,",
				"          CIOdirEmail,",
				"          TechMngrEmail,",
				"          Import_Date",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> SelectForSink",
				"SelectForSink sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'parquet',",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> SinkVulnHistoryAlerts"
			]
		}
	}
}