{
	"name": "DF_Collect_Daily_SII_Metric_2",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "Generic_src_parquet",
						"type": "DatasetReference"
					},
					"name": "DailySIIMetricView",
					"description": "Source: vw_SII_EmailAlerts_Details landed as Parquet by PPL_Generic_db_replication"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "Generic_tgt_parquet",
						"type": "DatasetReference"
					},
					"name": "tblSIIVulnHistoryAlerts",
					"description": "Sink: Parquet staging file. CPD_Blob_To_Onprem copies this into dbo.tbl_SII_Vuln_History_Alerts."
				}
			],
			"transformations": [
				{
					"name": "ImportDate",
					"description": "Derived Column: adds Import_Date = currentDate() matching SSIS (DT_DBDATE)DATEADD('day',0,GETDATE())"
				}
			],
			"scriptLines": [
				"source(output(",
				"          TotlInst as integer,",
				"          EmergencyCount as integer,",
				"          HMLCount_App as integer,",
				"          HMLCount_ProdPlat as integer,",
				"          Non_HMLCount_App as integer,",
				"          Non_HMLCount_ProdPlat as integer,",
				"          TechnicalManager_App1 as string,",
				"          Senior_Lead_Supplimented as string,",
				"          CIO_Direct_Supplimented as string,",
				"          Email_Level as string,",
				"          subject_ as string,",
				"          EMHAstatement as string,",
				"          HMLAPP as string,",
				"          HML_ProdPlat as string,",
				"          Non_HML_App as string,",
				"          Non_HML_ProdPlat as string,",
				"          SrMngrEmail as string,",
				"          CIOdirEmail as string,",
				"          TechMngrEmail as string",
				"     ),",
				"     allowSchemaDrift: false,",
				"     validateSchema: true,",
				"     ignoreNoFilesFound: false,",
				"     format: 'parquet') ~> DailySIIMetricView",
				"DailySIIMetricView derive(Import_Date = currentDate()) ~> ImportDate",
				"ImportDate sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'parquet',",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     mapColumn(",
				"          TotlInst,",
				"          EmergencyCount,",
				"          HMLCount_App,",
				"          HMLCount_ProdPlat,",
				"          Non_HMLCount_App,",
				"          Non_HMLCount_ProdPlat,",
				"          TechnicalManager_App1,",
				"          Senior_Lead_Supplimented,",
				"          CIO_Direct_Supplimented,",
				"          Email_Level,",
				"          subject_,",
				"          EMHAstatement,",
				"          HMLAPP,",
				"          HML_ProdPlat,",
				"          Non_HML_App,",
				"          Non_HML_ProdPlat,",
				"          SrMngrEmail,",
				"          CIOdirEmail,",
				"          TechMngrEmail,",
				"          Import_Date",
				"     )) ~> tblSIIVulnHistoryAlerts"
			]
		}
	}
}