{
	"name": "DF_Extract_Prev_Week_CollectUpdates",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "Generic_src_parquet",
						"type": "DatasetReference"
					},
					"name": "ExportFormat"
				},
				{
					"dataset": {
						"referenceName": "Generic_src_parquet",
						"type": "DatasetReference"
					},
					"name": "LookupSrc"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "Generic_tgt_parquet",
						"type": "DatasetReference"
					},
					"name": "OLEDBDestination"
				},
				{
					"dataset": {
						"referenceName": "Generic_tgt_parquet",
						"type": "DatasetReference"
					},
					"name": "OLEDBDestination1"
				}
			],
			"transformations": [
				{
					"name": "DerivedColumn"
				},
				{
					"name": "Multicast"
				},
				{
					"name": "LookupTransform"
				},
				{
					"name": "FilterNoMatch"
				},
				{
					"name": "RenameToDiff"
				},
				{
					"name": "RenameToPrevWeek"
				}
			],
			"scriptLines": [
				"source(output(",
				"          {PLHIS Contact} as string,",
				"          Notes as string,",
				"          Ramservername as string,",
				"          Lcmstatus as string,",
				"          TCOOStatus as string,",
				"          TCOOMigrationStatus as string,",
				"          Primarytechmgr as string,",
				"          Managedbygroup as string,",
				"          Environment as string,",
				"          Cio as string,",
				"          Ciodirect as string,",
				"          Cistatus as string,",
				"          Rtstatus as string,",
				"          Rtplannedactivity as string,",
				"          Fundingdate as string,",
				"          Rtdecomdate as string,",
				"          Rtplancertifieddate as string,",
				"          Hweoldate as string,",
				"          Applicationids as string,",
				"          Normalizedos as string,",
				"          {Eol Hw Thru 2023} as string,",
				"          {Hds Thru 2022} as string,",
				"          Cioname as string,",
				"          {Vm On Hds2022 Esx Depthru 2023} as string,",
				"          Productname as string,",
				"          {Hds Thru 2023} as string,",
				"          {Hds Thru 2024} as string,",
				"          MappedCIODirName as string,",
				"          Primaryapplication as string,",
				"          {TCOO Extension Aggregated} as string,",
				"          SourceCIODirName as string,",
				"          UpdateDate as string,",
				"          Import_date as string,",
				"          PAA_INDICATOR as string,",
				"          PAI_INDICATOR as string,",
				"          ChangeNumber as string,",
				"          Decom_Date as string,",
				"          Extension_Date as string,",
				"          ISPNumber as string",
				"     ),",
				"     allowSchemaDrift: false,",
				"     validateSchema: true,",
				"     ignoreNoFilesFound: false,",
				"     format: 'parquet',",
				"     columnDelimiter: ',',",
				"     escapeChar: '\\\\',",
				"     quoteChar: '\\\"',",
				"     firstRowAsHeader: true) ~> ExportFormat",
				"source(output(",
				"          Ramservername as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false,",
				"     format: 'parquet') ~> LookupSrc",
				"ExportFormat derive(Import_date1 = toDate(currentTimestamp()),",
				"          DecomDT = toDate(Decom_Date),",
				"          ExtDT = toDate(Extension_Date)) ~> DerivedColumn",
				"DerivedColumn split(true(),",
				"     true(),",
				"     disjoint: undefined) ~> Multicast@(ToLookup, ToDestDirect)",
				"Multicast@ToLookup, LookupSrc lookup(Multicast@ToLookup@Ramservername == LookupSrc@Ramservername,",
				"     multiple: false,",
				"     pickup: 'any',",
				"     broadcast: 'auto',",
				"     noMatchBehavior: 'noMatchOutput')~> LookupTransform",
				"LookupTransform filter(isNull(LookupSrc@Ramservername)) ~> FilterNoMatch",
				"Multicast@ToDestDirect select(mapColumn(",
				"          {PLHIS Contact},",
				"          {PLHIS Updated Date} = UpdateDate,",
				"          Notes,",
				"          Ramservername,",
				"          Lcmstatus,",
				"          TCOOStatus,",
				"          TCOOMigrationStatus,",
				"          Ciodirectname = MappedCIODirName,",
				"          Primarytechmgr,",
				"          Managedbygroup,",
				"          {Primary Applicatioin} = Primaryapplication,",
				"          Environment,",
				"          Cio,",
				"          Ciodirect,",
				"          Cistatus,",
				"          Rtstatus,",
				"          Rtplannedactivity,",
				"          Fundingdate,",
				"          Rtdecomdate,",
				"          Rtplancertifieddate,",
				"          Hweoldate,",
				"          Applicationids,",
				"          Normalizedos,",
				"          {Eol Hw Thru 2023},",
				"          {Hds Thru 2022},",
				"          Cioname,",
				"          {Vm On Hds2022 Esx Depthru 2023},",
				"          Productname,",
				"          {Hds Thru 2023},",
				"          {Hds Thru 2024},",
				"          sourceCIOdirName = SourceCIODirName,",
				"          {TCOO Extension Aggregated},",
				"          NewSourceLCM_AsOf = Import_date,",
				"          ChangeNumber = DecomDT,",
				"          Decom_Date = ExtDT,",
				"          Extension_Date = MappedCIODirName,",
				"          ISPNumber,",
				"          Import_date = Import_date1",
				"     ),",
				"     skipDuplicateMapInputs: false,",
				"     skipDuplicateMapOutputs: true) ~> RenameToDiff",
				"FilterNoMatch select(mapColumn(",
				"          {PLHIS Contact},",
				"          Ramservername = Notes,",
				"          Lcmstatus = Ramservername,",
				"          TCOOStatus = Lcmstatus,",
				"          TCOOMigrationStatus = TCOOStatus,",
				"          {TCOO Extension Aggregated} = TCOOMigrationStatus,",
				"          Notes = Primarytechmgr,",
				"          ChangeNumber = Managedbygroup,",
				"          Decom_Date = Environment,",
				"          Extension_Date = Cio,",
				"          Ciodirectname = Ciodirect,",
				"          Primarytechmgr = Cistatus,",
				"          Managedbygroup = Rtstatus,",
				"          Primaryapplication = Rtplannedactivity,",
				"          Environment = Fundingdate,",
				"          Applicationids = Rtdecomdate,",
				"          Cistatus = Rtplancertifieddate,",
				"          Rtstatus = Hweoldate,",
				"          Rtplannedactivity = Applicationids,",
				"          Fundingdate = Normalizedos,",
				"          Rtdecomdate = {Eol Hw Thru 2023},",
				"          Rtplancertifieddate = {Hds Thru 2022},",
				"          Hweoldate = Cioname,",
				"          Normalizedos = {Vm On Hds2022 Esx Depthru 2023},",
				"          {Eol Hw Thru 2023} = Productname,",
				"          {Hds Thru 2022} = {Hds Thru 2023},",
				"          Cioname = {Hds Thru 2024},",
				"          {Vm On Hds2022 Esx Depthru 2023} = Primaryapplication,",
				"          Productname = {TCOO Extension Aggregated},",
				"          {Hds Thru 2023} = ChangeNumber,",
				"          {Hds Thru 2024} = ISPNumber,",
				"          Cio = Import_date,",
				"          Ciodirect = MappedCIODirName,",
				"          ISPNumber = DecomDT,",
				"          Import_date = ExtDT",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> RenameToPrevWeek",
				"RenameToDiff sink(allowSchemaDrift: true,",
				"     validateSchema: true,",
				"     format: 'parquet',",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     mapColumn(",
				"          PLHIS_Contact = {PLHIS Contact},",
				"          PLHIS_Updated_Date = {PLHIS Updated Date},",
				"          Notes,",
				"          Ramservername,",
				"          Lcmstatus,",
				"          TCOOStatus,",
				"          TCOOMigrationStatus,",
				"          Ciodirectname,",
				"          Primarytechmgr,",
				"          Managedbygroup,",
				"          Primary_Applicatioin = {Primary Applicatioin},",
				"          Environment,",
				"          Cio,",
				"          Ciodirect,",
				"          Cistatus,",
				"          Rtstatus,",
				"          Rtplannedactivity,",
				"          Fundingdate,",
				"          Rtdecomdate,",
				"          Rtplancertifieddate,",
				"          Hweoldate,",
				"          Applicationids,",
				"          Normalizedos,",
				"          Eol_Hw_Thru_2023 = {Eol Hw Thru 2023},",
				"          Hds_Thru_2022 = {Hds Thru 2022},",
				"          Cioname,",
				"          Vm_On_Hds2022_Esx_Depthru_2023 = {Vm On Hds2022 Esx Depthru 2023},",
				"          Productname,",
				"          Hds_Thru_2023 = {Hds Thru 2023},",
				"          Hds_Thru_2024 = {Hds Thru 2024},",
				"          sourceCIOdirName,",
				"          TCOO_Extension_Aggregated = {TCOO Extension Aggregated},",
				"          NewSourceLCM_AsOf,",
				"          ChangeNumber,",
				"          Decom_Date,",
				"          Extension_Date,",
				"          ISPNumber,",
				"          Import_date",
				"     )) ~> OLEDBDestination",
				"RenameToPrevWeek sink(allowSchemaDrift: true,",
				"     validateSchema: true,",
				"     format: 'parquet',",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     mapColumn(",
				"          PLHIS_Contact = {PLHIS Contact},",
				"          Ramservername,",
				"          TCOOStatus,",
				"          TCOOMigrationStatus,",
				"          TCOO_Extension_Aggregated = {TCOO Extension Aggregated},",
				"          Notes,",
				"          ChangeNumber,",
				"          Decom_Date,",
				"          Extension_Date,",
				"          Ciodirectname,",
				"          Primarytechmgr,",
				"          Managedbygroup,",
				"          Primaryapplication,",
				"          Environment,",
				"          Applicationids,",
				"          Cistatus,",
				"          Rtstatus,",
				"          Rtplannedactivity,",
				"          Fundingdate,",
				"          Rtdecomdate,",
				"          Rtplancertifieddate,",
				"          Hweoldate,",
				"          Normalizedos,",
				"          Eol_Hw_Thru_2023 = {Eol Hw Thru 2023},",
				"          Hds_Thru_2022 = {Hds Thru 2022},",
				"          Cioname,",
				"          Vm_On_Hds2022_Esx_Depthru_2023 = {Vm On Hds2022 Esx Depthru 2023},",
				"          Productname,",
				"          Hds_Thru_2023 = {Hds Thru 2023},",
				"          Hds_Thru_2024 = {Hds Thru 2024},",
				"          Cio,",
				"          Ciodirect,",
				"          ISPNumber,",
				"          Import_date",
				"     )) ~> OLEDBDestination1"
			]
		}
	}
}