          "typeProperties" : {
            "scripts" : [ {
              "type" : "Query",
              "text" : "\nSELECT CONVERT(varchar, min([TheDate]),23) FROM [SA4NAV4_EDW_RCSAS].[dbo].[EDW Time] \nWHERE [MarsYear]=  ( SELECT CASE WHEN SUBSTRING([MarsPeriod],2,2) = '13' \n THEN [MarsYear] - 2 ELSE [MarsYear] - 3 END \nFROM [SA4NAV4_EDW_RCSAS].[dbo].[EDW Time] WHERE CONVERT( date, GETDATE())=[DateName]\n) \nAND [MarsPeriod]= ( SELECT CASE WHEN SUBSTRING([MarsPeriod],2,2) = '13' THEN 'P01' \nELSE CASE WHEN CONVERT(INT, SUBSTRING([MarsPeriod],2,2)) + 1 < 10 THEN 'P0' + CONVERT(VARCHAR(2), CONVERT(INT, SUBSTRING([MarsPeriod],2,2)) + 1)\n  ELSE 'P'+ CONVERT(VARCHAR(2), CONVERT(INT, SUBSTRING([MarsPeriod],2,2)) + 1) END  END \nFROM [SA4NAV4_EDW_RCSAS].[dbo].[EDW Time] WHERE CONVERT( date, GETDATE())=[DateName]\n)\n\n"
