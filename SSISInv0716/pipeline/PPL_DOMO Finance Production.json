          "text" : "DECLARE @RunDate DATETIME = CONCAT (YEAR(GETDATE()), '-', MONTH(GETDATE()), '-02')\nDECLARE @Count INT = 0\nDECLARE @CountOffset INT = 1\n\nIF DATEPART(WEEKDAY, @RunDate - 1) NOT IN (1,7)\nBEGIN\n\tSET @Count = @Count + 1\nEND\n\nWHILE DATEPART(WEEKDAY, @RunDate) IN (1, 7)\nBEGIN\n\tSET @RunDate = DATEADD(DAY, 1, @RunDate)\nEND\n\nWHILE @Count < @CountOffset\nBEGIN\n\tSET @RunDate = DATEADD(DAY, 1, @RunDate)\n\tSET @Count = @Count + 1\nEND\n\n--SET @RunDate = DATEADD(DAY, 1, @RunDate)\n\nSELECT CASE WHEN @RunDate = CAST(GETDATE() AS DATE)\n\t\tTHEN 1\n\t\tELSE 0\n\t\tEND"
