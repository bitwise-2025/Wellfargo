						"sqlReaderQuery": "SELECT\n    (SELECT PARAMETER_VALUE FROM AZ_PARAMETERS WHERE PARAMETER_NAME = 'Pipeline_Name' AND PIPELINE_NAME = 'PPL_PCF_Weekly_1' AND DATAFLOW_NAME = 'DF_New_PCF_File_Format') AS Pipeline_Name,\n    (SELECT PARAMETER_VALUE FROM AZ_PARAMETERS WHERE PARAMETER_NAME = 'Dataflow_Name' AND PIPELINE_NAME = 'PPL_PCF_Weekly_1' AND DATAFLOW_NAME = 'DF_New_PCF_File_Format') AS Dataflow_Name,\n    (SELECT PARAMETER_VALUE FROM AZ_PARAMETERS WHERE PARAMETER_NAME = 'Dataflow_Name_validate' AND PIPELINE_NAME = 'PPL_PCF_Weekly_1' AND DATAFLOW_NAME = 'DF_New_PCF_File_Format') AS Dataflow_Name_validate,\n    (SELECT PARAMETER_VALUE FROM AZ_PARAMETERS WHERE PARAMETER_NAME = 'Src_Container_Name' AND PIPELINE_NAME = 'PPL_PCF_Weekly_1' AND DATAFLOW_NAME = 'DF_New_PCF_File_Format') AS Src_Container_Name,\n    (SELECT PARAMETER_VALUE FROM AZ_PARAMETERS WHERE PARAMETER_NAME = 'Src_filename_Name' AND PIPELINE_NAME = 'PPL_PCF_Weekly_1' AND DATAFLOW_NAME = 'DF_New_PCF_File_Format') AS Src_filename,\n    (SELECT PARAMETER_VALUE FROM AZ_PARAMETERS WHERE PARAMETER_NAME = 'Src_path_Name' AND PIPELINE_NAME = 'PPL_PCF_Weekly_1' AND DATAFLOW_NAME = 'DF_New_PCF_File_Format') AS Src_path_Name,\n    (SELECT PARAMETER_VALUE FROM AZ_PARAMETERS WHERE PARAMETER_NAME = 'Tgt_Container_Name' AND PIPELINE_NAME = 'PPL_PCF_Weekly_1' AND DATAFLOW_NAME = 'DF_New_PCF_File_Format') AS Tgt_Container_Name,\n    (SELECT PARAMETER_VALUE FROM AZ_PARAMETERS WHERE PARAMETER_NAME = 'Tgt_filename_Name' AND PIPELINE_NAME = 'PPL_PCF_Weekly_1' AND DATAFLOW_NAME = 'DF_New_PCF_File_Format') AS Tgt_filename,\n    (SELECT PARAMETER_VALUE FROM AZ_PARAMETERS WHERE PARAMETER_NAME = 'Tgt_path_Name' AND PIPELINE_NAME = 'PPL_PCF_Weekly_1' AND DATAFLOW_NAME = 'DF_New_PCF_File_Format') AS Tgt_path_Name,\n    (SELECT PARAMETER_VALUE FROM AZ_PARAMETERS WHERE PARAMETER_NAME = 'Table_Name' AND PIPELINE_NAME = 'PPL_PCF_Weekly_1' AND DATAFLOW_NAME = 'DF_New_PCF_File_Format') AS Tgt_Table_Name,\n    (SELECT PARAMETER_VALUE FROM AZ_PARAMETERS WHERE PARAMETER_NAME = 'Schema_Name' AND PIPELINE_NAME = 'PPL_PCF_Weekly_1' AND DATAFLOW_NAME = 'DF_New_PCF_File_Format') AS Tgt_Schema_Name,",
