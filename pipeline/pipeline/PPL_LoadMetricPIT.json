				"description": "Executes dataflow 242_Load_MetSource. DTSX source 'Pit': OLE DB, AccessMode=2 (SQL command), [PLHS].[dbo].[tbl_VulnActive_Daily_PIT_MetricsSource] with date filter. DTSX destination 'OLE DB Destination': [dbo].[tbl_VulnActive_Daily_PIT_MetricsSource_dev].",
				"type": "ExecuteDataFlow",
				"onInactiveMarkAs": null,
				"dependsOn": [
					{
						"activity": "PPL_Generic_db_replication",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"policy": {
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
