          "text" : "-- Connection = Data_Staging\n-- 5 \"MyTable\" replacements\n\nSET NOCOUNT ON;\n\nDECLARE\t@DeleteITEMID TABLE(\n\t[ITEMID]\tNVARCHAR(40)\tNULL);\n\nINSERT INTO @DeleteITEMID(\n\t[ITEMID])\n-- Delete the following records\n-- Records with different verion\nSELECT\t[s].[ITEMID]\nFROM\t[ax].[INVENTTABLE] [s] INNER JOIN [dbo].[ztmp_INVENTTABLE_IDs] [a]\n\tON (\n\t\t([s].[ITEMID] = [a].[ITEMID])\n\tAND\n\t\t([s].[PARTITION] = [a].[PARTITION])\n\tAND\n\t\t([s].[DATAAREAID] = [a].[DATAAREAID])\n\t)\nWHERE\t[a].[RECVERSION] != [s].[RECVERSION];\n\nINSERT INTO @DeleteITEMID(\n\t[ITEMID])\n-- Records that exist in Staging but no longer exist in AX\nSELECT\t[ITEMID]\nFROM\t[ax].[INVENTTABLE] \n\tEXCEPT\nSELECT\t[ITEMID]\nFROM\t[dbo].[ztmp_INVENTTABLE_IDs];\n\nDELETE\nFROM\t[ax].[INVENTTABLE]\nWHERE\t[ITEMID] IN (SELECT [ITEMID] FROM @DeleteITEMID);"
        } ],
