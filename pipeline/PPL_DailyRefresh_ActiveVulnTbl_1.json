AMETER_VALUE FROM AZ_PARAMETERS WHERE PARAMETER_NAME = 'Table_Name' AND PIPELINE_NAME = 'PPL_DailyRefresh_ActiveVulnTbl_1' AND DATAFLOW_NAME = 'DF_Load_Daily_Vuln_from_View') AS Tgt_Table_Name,\n    (SELECT PARAMETER_VALUE FROM AZ_PARAMETERS WHERE PARAMETER_NAME = 'Schema_Name' AND PIPELINE_NAME = 'PPL_DailyRefresh_ActiveVulnTbl_1' AND DATAFLOW_NAME = 'DF_Load_Daily_Vuln_from_View') AS Tgt_Schema_Name,\n\t    (SELECT PARAMETER_VALUE FROM AZ_PARAMETERS WHERE PARAMETER_NAME = 'Dataflow_Name' AND PIPELINE_NAME = 'PPL_DailyRefresh_ActiveVulnTbl_1' AND DATAFLOW_NAME = 'DF_Load_Daily_Vuln_from_Stage') AS Dataflow_Name_2,\n    (SELECT PARAMETER_VALUE FROM AZ_PARAMETERS WHERE PARAMETER_NAME = 'Dataflow_Name_validate' AND PIPELINE_NAME = 'PPL_DailyRefresh_ActiveVulnTbl_1' AND DATAFLOW_NAME = 'DF_Load_Daily_Vuln_from_Stage') AS Dataflow_Name_validate_2,\n    (SELECT PARAMETER_VALUE FROM AZ_PARAMETERS WHERE PARAMETER_NAME = 'Src_Container_Name_2' AND PIPELINE_NAME = 'PPL_DailyRefresh_ActiveVulnTbl_1' AND DATAFLOW_NAME = 'DF_Load_Daily_Vuln_from_Stage') AS Src_Container_Name_2,\n    (SELECT PARAMETER_VALUE FROM AZ_PARAMETERS WHERE PARAMETER_NAME = 'Src_filename_Name_2' AND PIPELINE_NAME = 'PPL_DailyRefresh_ActiveVulnTbl_1' AND DATAFLOW_NAME = 'DF_Load_Daily_Vuln_from_Stage') AS Src_filename_2,\n    (SELECT PARAMETER_VALUE FROM AZ_PARAMETERS WHERE PARAMETER_NAME = 'Src_path_Name_2' AND PIPELINE_NAME = 'PPL_DailyRefresh_ActiveVulnTbl_1' AND DATAFLOW_NAME = 'DF_Load_Daily_Vuln_from_Stage') AS Src_path_Name_2,\n    (SELECT PARAMETER_VALUE FROM AZ_PARAMETERS WHERE PARAMETER_NAME = 'Tgt_Container_Name_2' AND PIPELINE_NAME = 'PPL_DailyRefresh_ActiveVulnTbl_1' AND DATAFLOW_NAME = 'DF_Load_Daily_Vuln_from_Stage') AS Tgt_Container_Name_2,\n    (SELECT PARAMETER_VALUE FROM AZ_PARAMETERS WHERE PARAMETER_NAME = 'Tgt_filename_Name_2' AND PIPELINE_NAME = 'PPL_DailyRefresh_ActiveVulnTbl_1' AND DATAFLOW_NAME = 'DF_Load_Daily_Vuln_from_Stage') AS Tgt_filename_2,\n    (SELECT PARAMETER_VALUE FROM