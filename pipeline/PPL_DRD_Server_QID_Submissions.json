 'Table_Name' AND PIPELINE_NAME = 'PPL_DRD_Server_QID_Submissions' AND DATAFLOW_NAME = 'DF_DOMSPT_FILE_FIND_LOAD') AS Tgt_Table_Name,\n    (SELECT PARAMETER_VALUE FROM AZ_PARAMETERS WHERE PARAMETER_NAME = 'Schema_Name' AND PIPELINE_NAME = 'PPL_DRD_Server_QID_Submissions' AND DATAFLOW_NAME = 'DF_DOMSPT_FILE_FIND_LOAD') AS Tgt_Schema_Name,\n    (SELECT PARAMETER_VALUE FROM AZ_PARAMETERS WHERE PARAMETER_NAME = 'Src_Container_Name_2' AND PIPELINE_NAME = 'PPL_DRD_Server_QID_Submissions' AND DATAFLOW_NAME = 'DF_DOMSPT_FILE_FIND_LOAD') AS Src_Container_Name_2,\n    (SELECT PARAMETER_VALUE FROM AZ_PARAMETERS WHERE PARAMETER_NAME = 'Src_filename_Name_2' AND PIPELINE_NAME = 'PPL_DRD_Server_QID_Submissions' AND DATAFLOW_NAME = 'DF_DOMSPT_FILE_FIND_LOAD') AS Src_filename_2,\n    (SELECT PARAMETER_VALUE FROM AZ_PARAMETERS WHERE PARAMETER_NAME = 'Src_path_Name_2' AND PIPELINE_NAME = 'PPL_DRD_Server_QID_Submissions' AND DATAFLOW_NAME = 'DF_DOMSPT_FILE_FIND_LOAD') AS Src_path_Name_2,\n    (SELECT PARAMETER_VALUE FROM AZ_PARAMETERS WHERE PARAMETER_NAME = 'Tgt_Container_Name_2' AND PIPELINE_NAME = 'PPL_DRD_Server_QID_Submissions' AND DATAFLOW_NAME = 'DF_DOMSPT_FILE_FIND_LOAD') AS Tgt_Container_Name_2,\n    (SELECT PARAMETER_VALUE FROM AZ_PARAMETERS WHERE PARAMETER_NAME = 'Tgt_filename_Name_2' AND PIPELINE_NAME = 'PPL_DRD_Server_QID_Submissions' AND DATAFLOW_NAME = 'DF_DOMSPT_FILE_FIND_LOAD') AS Tgt_filename_2,\n    (SELECT PARAMETER_VALUE FROM AZ_PARAMETERS WHERE PARAMETER_NAME = 'Tgt_path_Name_2' AND PIPELINE_NAME = 'PPL_DRD_Server_QID_Submissions' AND DATAFLOW_NAME = 'DF_DOMSPT_FILE_FIND_LOAD') AS Tgt_path_Name_2,\n    (SELECT PARAMETER_VALUE FROM AZ_PARAMETERS WHERE PARAMETER_NAME = 'Table_Name_2' AND PIPELINE_NAME = 'PPL_DRD_Server_QID_Submissions' AND DATAFLOW_NAME = 'DF_DOMSPT_FILE_FIND_LOAD') AS Tgt_Table_Name_2,\n    (SELECT PARAMETER_VALUE FROM AZ_PARAMETERS WHERE PARAMETER_NAME = 'Schema_Name_2' AND PIPELINE_NAME = 'PPL_DRD_Server_QID_Submissions' AND DATAFLOW_NAME = 'DF_DO