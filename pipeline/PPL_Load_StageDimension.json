          "type" : "Query",
          "text" : "IF OBJECT_ID('TempDB..##tmpCurrentUpdateIDs') IS NOT NULL\n\nDROP TABLE ##tmpCurrentUpdateIDs;\n\nCREATE TABLE ##tmpCurrentUpdateIDs (\n TableID int NOT NULL,\n  ETLDateCreated datetime NOT NULL,\n  ETLCreatedBy varchar(250) NOT NULL\n)\n\nINSERT INTO ##tmpCurrentUpdateIDs (TableID, ETLDateCreated, ETLCreatedBy) \nSELECT s.StageID, c.ETLDateCreated, c.ETLCreatedBy \nFROM stg.StageDimension s \nINNER JOIN rpt.StageDimension d \nON d.StageID = s.StageID \nINNER JOIN ##tmpCreateDates c\nON d.StageID = c.TableID\nWHERE s.ETLHashKey != d.ETLHashKey AND d.IsCurrent = 'Y'"
        } ],
