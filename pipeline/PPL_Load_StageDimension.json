          "text" : "CREATE TABLE ##tmpCreateDates(\n\tTableID int,\n\tETLDateCreated datetime,\n\tETLCreatedBy varchar(200)\n);\n\nINSERT INTO ##tmpCreateDates SELECT d.StageID, MIN(d.ETLDateCreated), d.ETLCreatedBy FROM rpt.StageDimension d \nWHERE d.IsCurrent = 'Y'\nGROUP BY d.StageID, d.ETLCreatedBy\n"
