						"sqlReaderQuery": "SELECT\n    (SELECT PARAMETER_VALUE FROM AZ_PARAMETERS WHERE PARAMETER_NAME = 'Dataflow_Name' AND PIPELINE_NAME = 'PPL_Tableau_QVRU_T_Th' AND DATAFLOW_NAME = 'DF_Summary_Report_Import') AS Dataflow_Name,\n    (SELECT PARAMETER_VALUE FROM AZ_PARAMETERS WHERE PARAMETER_NAME = 'Pipeline_Name' AND PIPELINE_NAME = 'PPL_Tableau_QVRU_T_Th' AND DATAFLOW_NAME = 'DF_Summary_Report_Import') AS Pipeline_Name,\n    (SELECT PARAMETER_VALUE FROM AZ_PARAMETERS WHERE PARAMETER_NAME = 'Src_Container_Name' AND PIPELINE_NAME = 'PPL_Tableau_QVRU_T_Th' AND DATAFLOW_NAME = 'DF_Summary_Report_Import') AS Src_Container_Name,\n    (SELECT PARAMETER_VALUE FROM AZ_PARAMETERS WHERE PARAMETER_NAME = 'Src_filename_Name' AND PIPELINE_NAME = 'PPL_Tableau_QVRU_T_Th' AND DATAFLOW_NAME = 'DF_Summary_Report_Import') AS Src_filename,\n    (SELECT PARAMETER_VALUE FROM AZ_PARAMETERS WHERE PARAMETER_NAME = 'Src_path_Name' AND PIPELINE_NAME = 'PPL_Tableau_QVRU_T_Th' AND DATAFLOW_NAME = 'DF_Summary_Report_Import') AS Src_path_Name,\n    (SELECT PARAMETER_VALUE FROM AZ_PARAMETERS WHERE PARAMETER_NAME = 'Tgt_Container_Name' AND PIPELINE_NAME = 'PPL_Tableau_QVRU_T_Th' AND DATAFLOW_NAME = 'DF_Summary_Report_Import') AS Tgt_Container_Name,\n    (SELECT PARAMETER_VALUE FROM AZ_PARAMETERS WHERE PARAMETER_NAME = 'Tgt_filename_Name' AND PIPELINE_NAME = 'PPL_Tableau_QVRU_T_Th' AND DATAFLOW_NAME = 'DF_Summary_Report_Import') AS Tgt_filename,\n    (SELECT PARAMETER_VALUE FROM AZ_PARAMETERS WHERE PARAMETER_NAME = 'Tgt_path_Name' AND PIPELINE_NAME = 'PPL_Tableau_QVRU_T_Th' AND DATAFLOW_NAME = 'DF_Summary_Report_Import') AS Tgt_path_Name,\n    (SELECT PARAMETER_VALUE FROM AZ_PARAMETERS WHERE PARAMETER_NAME = 'Table_Name' AND PIPELINE_NAME = 'PPL_Tableau_QVRU_T_Th' AND DATAFLOW_NAME = 'DF_Summary_Report_Import') AS Tgt_Table_Name,\n    (SELECT PARAMETER_VALUE FROM AZ_PARAMETERS WHERE PARAMETER_NAME = 'Schema_Name' AND PIPELINE_NAME = 'PPL_Tableau_QVRU_T_Th' AND DATAFLOW_NAME = 'DF_Summary_Report_Import') AS Tgt_Schema_Name;",
