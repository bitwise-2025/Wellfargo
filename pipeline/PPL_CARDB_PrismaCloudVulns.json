								"type": "Expression"
							}
						}
					}
				]
			},
			{
				"name": "LKP_Fetch_Param",
				"type": "Lookup",
				"dependsOn": [],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "AzureSqlSource",
						"sqlReaderQuery": "SELECT\n    (SELECT PARAMETER_VALUE FROM AZ_PARAMETERS WHERE PARAMETER_NAME = 'Pipeline_Name' AND PIPELINE_NAME = 'PPL_CARDB_PrismaCloudVulns' AND DATAFLOW_NAME = 'DF_Prisma_ETL') AS Pipeline_Name,\n    (SELECT PARAMETER_VALUE FROM AZ_PARAMETERS WHERE PARAMETER_NAME = 'Dataflow_Name' AND PIPELINE_NAME = 'PPL_CARDB_PrismaCloudVulns' AND DATAFLOW_NAME = 'DF_Prisma_ETL') AS Dataflow_Name,\n    (SELECT PARAMETER_VALUE FROM AZ_PARAMETERS WHERE PARAMETER_NAME = 'Dataflow_Name_validate' AND PIPELINE_NAME = 'PPL_CARDB_PrismaCloudVulns' AND DATAFLOW_NAME = 'DF_Prisma_ETL') AS Dataflow_Name_validate,\n    (SELECT PARAMETER_VALUE FROM AZ_PARAMETERS WHERE PARAMETER_NAME = 'Src_Container_Name' AND PIPELINE_NAME = 'PPL_CARDB_PrismaCloudVulns' AND DATAFLOW_NAME = 'DF_Prisma_ETL') AS Src_Container_Name,\n    (SELECT PARAMETER_VALUE FROM AZ_PARAMETERS WHERE PARAMETER_NAME = 'Src_filename_Name' AND PIPELINE_NAME = 'PPL_CARDB_PrismaCloudVulns' AND DATAFLOW_NAME = 'DF_Prisma_ETL') AS Src_filename,\n    (SELECT PARAMETER_VALUE FROM AZ_PARAMETERS WHERE PARAMETER_NAME = 'Src_path_Name' AND PIPELINE_NAME = 'PPL_CARDB_PrismaCloudVulns' AND DATAFLOW_NAME = 'DF_Prisma_ETL') AS Src_path_Name,\n    (SELECT PARAMETER_VALUE FROM AZ_PARAMETERS WHERE PARAMETER_NAME = 'Tgt_Container_Name' AND PIPELINE_NAME = 'PPL_CARDB_PrismaCloudVulns' AND DATAFLOW_NAME = 'DF_Prisma_ETL') AS Tgt_Container_Name,\n    (SELECT PARAMETER_VALUE FROM AZ_PARAMETERS WHERE PARAMETER_NAME = 'Tgt_filename_Name' AND PIPELINE_NAME = 'PPL_CARDB_PrismaCloudVulns' AND DATAFLOW_NAME = 'DF_Prisma_ETL') AS Tgt_filename,\n    (SELECT PARAMETER_VALUE FROM AZ_PARAMETERS WHERE PARAMETER_NAME = 'Tgt_path_Name' AND PIPELINE_NAME = 'PPL_CARDB_PrismaCloudVulns' AND DATAFLOW_NAME = 'DF_Prisma_ETL') AS Tgt_path_Name,\n    (SELECT PARAMETER_VALUE FROM AZ_PARAMETERS WHERE PARAMETER_NAME = 'Table_Name' AND PIPELINE_NAME = 'PPL_CARDB_PrismaCloudVulns' AND DATAFLOW_NAME = 'DF_Prisma_ETL') AS Tgt_Table_Name,\n    (SELECT PARAMETER_VALUE FROM AZ_PARAMETERS WHERE PARAMETER_NAME = 'Schema_Name' AND PIPELINE_NAME = 'PPL_CARDB_PrismaCloudVulns' AND DATAFLOW_NAME = 'DF_Prisma_ETL') AS Tgt_Schema_Name,\n\t\t    (SELECT PARAMETER_VALUE FROM AZ_PARAMETERS WHERE PARAMETER_NAME = 'Dataflow_Name' AND PIPELINE_NAME = 'PPL_CARDB_PrismaCloudVulns' AND DATAFLOW_NAME = 'DF_ETL_PrismaRegistry') AS Dataflow_Name_3,\n    (SELECT PARAMETER_VALUE FROM AZ_PARAMETERS WHERE PARAMETER_NAME = 'Dataflow_Name_validate' AND PIPELINE_NAME = 'PPL_CARDB_PrismaCloudVulns' AND DATAFLOW_NAME = 'DF_ETL_PrismaRegistry') AS Dataflow_Name_validate_3,\n    (SELECT PARAMETER_VALUE FROM AZ_PARAMETERS WHERE PARAMETER_NAME = 'Src_Container_Name_2' AND PIPELINE_NAME = 'PPL_CARDB_PrismaCloudVulns' AND DATAFLOW_NAME = 'DF_ETL_PrismaRegistry') AS Src_Container_Name_3,\n    (SELECT PARAMETER_VALUE FROM AZ_PARAMETERS WHERE PARAMETER_NAME = 'Src_filename_Name_2' AND PIPELINE_NAME = 'PPL_CARDB_PrismaCloudVulns' AND DATAFLOW_NAME = 'DF_ETL_PrismaRegistry') AS Src_filename_3,\n    (SELECT PARAMETER_VALUE FROM AZ_PARAMETERS WHERE PARAMETER_NAME = 'Src_path_Name_2' AND PIPELINE_NAME = 'PPL_CARDB_PrismaCloudVulns' AND DATAFLOW_NAME = 'DF_ETL_PrismaRegistry') AS Src_path_Name_3,\n    (SELECT PARAMETER_VALUE FROM AZ_PARAMETERS WHERE PARAMETER_NAME = 'Tgt_Container_Name_2' AND PIPELINE_NAME = 'PPL_CARDB_PrismaCloudVulns' AND DATAFLOW_NAME = 'DF_ETL_PrismaRegistry') AS Tgt_Container_Name_3,\n    (SELECT PARAMETER_VALUE FROM AZ_PARAMETERS WHERE PARAMETER_NAME = 'Tgt_filename_Name_2' AND PIPELINE_NAME = 'PPL_CARDB_PrismaCloudVulns' AND DATAFLOW_NAME = 'DF_ETL_PrismaRegistry') AS Tgt_filename_3,\n    (SELECT PARAMETER_VALUE FROM AZ_PARAMETERS WHERE PARAMETER_NAME = 'Tgt_path_Name_2' AND PIPELINE_NAME = 'PPL_CARDB_PrismaCloudVulns' AND DATAFLOW_NAME = 'DF_ETL_PrismaRegistry') AS Tgt_path_Name_3,\n    (SELECT PARAMETER_VALUE FROM AZ_PARAMETERS WHERE PARAMETER_NAME = 'Table_Name_2' AND PIPELINE_NAME = 'PPL_CARDB_PrismaCloudVulns' AND DATAFLOW_NAME = 'DF_ETL_PrismaRegistry') AS Tgt_Table_Name_3,\n    (SELECT PARAMETER_VALUE FROM AZ_PARAMETERS WHERE PARAMETER_NAME = 'Schema_Name_2' AND PIPELINE_NAME = 'PPL_CARDB_PrismaCloudVulns' AND DATAFLOW_NAME = 'DF_ETL_PrismaRegistry') AS Tgt_Schema_Name_3;",
						"queryTimeout": "02:00:00",
						"partitionOption": "None"
					},
					"dataset": {
						"referenceName": "DS_Metadata",
						"type": "DatasetReference"
					}
				}
			},
			{
				"name": "Sequence_Container_6_Check_Source_Availability",
				"type": "SetVariable",
				"dependsOn": [
					{
						"activity": "ST_Check_Source_Availability",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"policy": {
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"variableName": "RegistryCount",
					"value": {
						"value": "@activity('ST_Check_Source_Availability').output.resultSets[0].rows[0].RegistryCount",
						"type": "Expression"
					}
				}
			},
			{
				"name": "If_RegistryCount_GT_Zero",
				"description": "Replicates SSIS precedence constraint expression '@[User::RegistryCount] > 0' between Check Source Availability and Truncate PrismaRegistry_Enriched. Only proceeds with truncate + ETL if rows exist.",
				"type": "IfCondition",
				"dependsOn": [
					{
						"activity": "Sequence_Container_6_Check_Source_Availability",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"userProperties": [],
				"typeProperties": {
					"expression": {
						"value": "@greater(int(activity('ST_Check_Source_Availability').output.firstRow.reccount), 0)",
						"type": "Expression"
					},
					"ifFalseActivities": [
						{
							"name": "Skip_PrismaRegistry_No_Rows",
							"description": "No-op placeholder: source returned 0 rows, mirroring SSIS constraint blocking execution when RegistryCount = 0.",
							"type": "Wait",
							"dependsOn": [],
							"userProperties": [],
							"typeProperties": {
								"waitTimeInSeconds": 1
							}
						}
					],
					"ifTrueActivities": [
						{
