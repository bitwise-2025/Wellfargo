								"retry": 0,
								"retryIntervalInSeconds": 30,
								"secureOutput": false,
								"secureInput": false
							},
							"userProperties": [],
							"linkedServiceName": {
								"referenceName": "dbdev_onprem",
								"type": "LinkedServiceReference"
							},
							"typeProperties": {
								"scripts": [
									{
										"type": "Query",
										"text": "TRUNCATE TABLE dbo.tbL_PrismaRegistry_Enriched"
									}
								]
							}
						},
						{
							"name": "DF_ETL_PrismaRegistry",
							"description": null,
							"type": "ExecuteDataFlow",
							"onInactiveMarkAs": null,
							"dependsOn": [
								{
									"activity": "PPL_Generic_db_replication_copy1",
									"dependencyConditions": [
										"Succeeded"
									]
								}
							],
							"policy": {
								"retry": 0,
								"retryIntervalInSeconds": 30,
								"secureOutput": false,
								"secureInput": false
							},
							"userProperties": [],
							"typeProperties": {
								"dataflow": {
									"referenceName": "DF_ETL_PrismaRegistry",
									"type": "DataFlowReference",
									"datasetParameters": {
										"vwPrismaRegistryEnrichedInfraDateFiltered": {
											"container": {
												"value": "@activity('LKP_Fetch_Param').output.firstRow.Src_Container_Name",
												"type": "Expression"
											},
											"path": "@activity('LKP_Fetch_Param').output.firstRow.Src_path_Name_3",
											"filename": {
												"value": "@activity('LKP_Fetch_Param').output.firstRow.Src_filename_3",
												"type": "Expression"
											}
										},
										"OLEDBDestination": {
											"path": "@activity('LKP_Fetch_Param').output.firstRow.Tgt_path_Name_3",
											"Container": "@activity('LKP_Fetch_Param').output.firstRow.Tgt_Container_Name_3",
											"filename": {
												"value": "@activity('LKP_Fetch_Param').output.firstRow.Tgt_filename_3",
												"type": "Expression"
											}
										}
									}
								},
								"compute": {
									"coreCount": 8,
									"computeType": "General"
								},
								"traceLevel": "Fine"
							}
						},
						{
							"name": "PPL_Generic_db_replication_copy1",
							"type": "ExecutePipeline",
							"dependsOn": [
								{
									"activity": "ST_Truncate_PrismaRegistry",
									"dependencyConditions": [
										"Succeeded"
									]
								}
							],
							"policy": {
								"secureInput": false
							},
							"userProperties": [],
							"typeProperties": {
								"pipeline": {
									"referenceName": "Generic_db_replication_ppl",
									"type": "PipelineReference"
								},
								"waitOnCompletion": true,
								"parameters": {
									"Pipeline_Name": {
										"value": "@activity('LKP_Fetch_Param').output.firstRow.Pipeline_Name",
										"type": "Expression"
									},
									"SysDatetime": {
										"value": "@formatDateTime(pipeline().TriggerTime,'yyyyMMddHHmmss')",
										"type": "Expression"
									},
									"FilePath_Date": {
										"value": "formatDateTime(pipeline().TriggerTime,'yyyyMMdd')",
										"type": "Expression"
									},
									"Dataflow_Name": {
										"value": "@activity('LKP_Fetch_Param').output.firstRow.Dataflow_Name",
										"type": "Expression"
									}
								}
							}
						},
						{
							"name": "CPD_Blob_To_Onprem_copy2",
							"type": "Copy",
							"dependsOn": [
								{
									"activity": "DF_ETL_PrismaRegistry",
									"dependencyConditions": [
										"Succeeded"
									]
								}
							],
							"policy": {
								"timeout": "0.12:00:00",
								"retry": 0,
								"retryIntervalInSeconds": 30,
								"secureOutput": false,
								"secureInput": false
							},
							"userProperties": [],
							"typeProperties": {
								"source": {
									"type": "ParquetSource",
									"storeSettings": {
										"type": "AzureBlobFSReadSettings",
										"recursive": true,
										"enablePartitionDiscovery": false
									},
									"formatSettings": {
										"type": "ParquetReadSettings"
									}
								},
								"sink": {
									"type": "AzureSqlSink",
									"writeBehavior": "insert",
									"sqlWriterUseTableLock": false
								},
								"enableStaging": false,
								"translator": {
									"type": "TabularTranslator",
									"typeConversion": true,
									"typeConversionSettings": {
										"allowDataTruncation": true,
										"treatBooleanAsNumber": false
									}
								}
							},
							"inputs": [
								{
									"referenceName": "Generic_tgt_parquet",
									"type": "DatasetReference",
									"parameters": {
										"path": {
											"value": "@activity('LKP_Fetch_Param').output.firstRow.Tgt_File_path",
											"type": "Expression"
										},
										"Container": {
											"value": "@activity('LKP_Fetch_Param').output.firstRow.Tgt_Container_Name",
											"type": "Expression"
										},
										"filename": {
											"value": "@activity('LKP_Fetch_Param').output.firstRow.Tgt_filename",
											"type": "Expression"
										}
									}
								}
							],
							"outputs": [
								{
									"referenceName": "Generic_OLEDB_DS_TGT",
									"type": "DatasetReference",
									"parameters": {
										"TableName": {
											"value": "@activity('LKP_Fetch_Param').output.firstRow.Table_Name",
											"type": "Expression"
										},
										"Schema": {
											"value": "@activity('LKP_Fetch_Param').output.firstRow.Schema_Name",
											"type": "Expression"
										}
									}
								}
							]
						}
					]
				}
			}
		],
		"variables": {
			"RegistryCount": {
				"type": "String"
			}
		},
		"folder": {
			"name": "Wellfargo1/COO_VulnPackages"
		},
		"annotations": []
	},
	"type": "Microsoft.DataFactory/factories/pipelines",
	"apiVersion": "2018-06-01"
}